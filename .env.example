# Токен Telegram бота (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# (Опционально) Google Safe Browsing API Key
# Получить: https://console.cloud.google.com/apis/api/safebrowsing.googleapis.com
# GOOGLE_SAFE_BROWSING_KEY=your_key_here

# (Опционально) VirusTotal API Key
# Получить: https://www.virustotal.com/gui/join-us
# VIRUSTOTAL_KEY=your_key_here

# (Опционально) OpenAI API Key — для LLM-анализа текста
# OPENAI_API_KEY=your_key_here

# Telegram user IDs админов (через запятую)
# ADMIN_IDS=123456789,987654321

# Webhook (для продакшена, вместо polling)
# WEBHOOK_URL=https://your-domain.com
# WEBHOOK_PATH=/webhook
# WEBAPP_HOST=0.0.0.0
# WEBAPP_PORT=8443

# Rate Limiting
# RATE_LIMIT=30
# RATE_WINDOW=60
