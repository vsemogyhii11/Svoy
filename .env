# ============================================
# БАЗА ДАННЫХ
# ============================================
DATABASE_URL=sqlite+aiosqlite:///data/svoy.db

# ============================================
# КЭШИРОВАНИЕ И ПРОИЗВОДИТЕЛЬНОСТЬ
# ============================================
# TTL кэша для API запросов (сек)
API_CACHE_TTL=3600
# TTL для WHOIS кэша (сек)
WHOIS_CACHE_TTL=86400
# Максимум запросов в минуту
RATE_LIMIT=30
# Окно rate limit (сек)
RATE_WINDOW=60

# ============================================
# OSINT АГЕНТЫ
# ============================================
# Интервал между циклами (сек)
OSINT_CYCLE_INTERVAL=180
# Глубина сканирования (страниц)
OSINT_SCAN_DEPTH=5
# Максимум параллельных задач
OSINT_MAX_CONCURRENT=20

# ============================================
# ЛОГИРОВАНИЕ
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/svoy_bot.log
LOG_MAX_SIZE_MB=10
LOG_BACKUP_COUNT=5

# ============================================
# МОНИТОРИНГ
# ============================================
ENABLE_HEALTH_CHECK=true
HEALTH_CHECK_PORT=5005
ENABLE_METRICS=true

# ============================================
# БЕЗОПАСНОСТЬ
# ============================================
# Заблокированные страны (через запятую)
BLOCKED_COUNTRIES=KP,IR,SY
# Разрешённые страны (None = все кроме blocked)
ALLOWED_COUNTRIES=RU,BY,KZ
# Порог для CAPTCHA
CAPTCHA_THRESHOLD=0.5
# AbuseIPDB ключ (опционально)
ABUSEIPDB_KEY=
